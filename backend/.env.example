# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yawallet.com

# Database
DB_NAME=yawallet
DB_USER=yawallet_user
DB_PASSWORD=secure_password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379

# Firebase
FIREBASE_CREDENTIALS=/path/to/firebase-credentials.json

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=ap-southeast-1

# NIFT API
NIFT_API_URL=https://api.nift.com/v1
NIFT_API_KEY=your-nift-api-key
NIFT_API_SECRET=your-nift-api-secret
NIFT_WEBHOOK_SECRET=your-webhook-secret

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# Admin
ADMIN_EMAIL=admin@yawallet.com

# Security
ENCRYPTION_KEY=your-encryption-key

# Feature Flags
KYC_ENABLED=True
P2P_ENABLED=True
IBFT_ENABLED=True
BILL_PAYMENT_ENABLED=True
QR_ENABLED=True

# Transaction Fees
TRANSACTION_FEE_PERCENT=1.0
TRANSACTION_FEE_MIN=10.0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# SSL
SECURE_SSL_REDIRECT=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
