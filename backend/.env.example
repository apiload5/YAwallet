# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yawallet.com
BASE_URL=https://yawallet.com

# Database
DB_NAME=yawallet
DB_USER=yawallet_user
DB_PASSWORD=change-this-strong-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_BROKER_URL=redis://redis:6379/0
REDIS_RESULT_BACKEND=redis://redis:6379/1

# Firebase (Option 1: File path)
FIREBASE_CREDENTIALS=/app/firebase-credentials.json

# OR Firebase (Option 2: Base64 encoded)
FIREBASE_CREDENTIALS_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Iiw...

# AWS S3
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_STORAGE_BUCKET_NAME=yawallet-media
AWS_S3_REGION_NAME=ap-southeast-1
AWS_S3_CUSTOM_DOMAIN=yawallet-media.s3.amazonaws.com

# NIFT API
NIFT_API_URL=https://api.nift.com/v1
NIFT_API_KEY=your-nift-api-key
NIFT_API_SECRET=your-nift-api-secret
NIFT_WEBHOOK_SECRET=your-webhook-secret

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@yawallet.com
EMAIL_HOST_PASSWORD=your-email-password

# Admin
ADMIN_EMAIL=admin@yawallet.com
ADMIN_NAME=YaWallet Admin

# Security
ENCRYPTION_KEY=your-encryption-key-here

# Feature Flags
KYC_ENABLED=True
P2P_ENABLED=True
IBFT_ENABLED=True
BILL_PAYMENT_ENABLED=True
QR_ENABLED=True

# Transaction Fees
TRANSACTION_FEE_PERCENT=1.0
TRANSACTION_FEE_MIN=10.0
TRANSACTION_FEE_MAX=500.0

# CORS
CORS_ALLOWED_ORIGINS=https://yawallet.com,https://www.yawallet.com

# SSL
SECURE_SSL_REDIRECT=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# Celery
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=True

# Rate Limiting
RATELIMIT_ENABLE=True
RATELIMIT_VIEW=apps.core.throttling.rate_limit_exceeded

# Session
SESSION_COOKIE_AGE=900
SESSION_EXPIRE_AT_BROWSER_CLOSE=True
SESSION_COOKIE_HTTPONLY=True

# Security
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS='DENY'

# Database Pool
DB_CONN_MAX_AGE=60
DB_CONN_MAX_AGE_CELERY=30

# Monitoring
SENTRY_DSN=your-sentry-dsn-if-using

# Backup
BACKUP_ENABLED=True
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
